# ── App ───────────────────────────────────────────────
APP_NAME=DevOps Copilot Swarm
APP_VERSION=2.0.0
APP_ENV=production
DEBUG=False

# ── Security ──────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-minimum-64-chars-here

# ── Database ──────────────────────────────────────────
# Local SQLite (development)
DATABASE_URL=sqlite:///database/devops.db

# Production PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/devops_swarm

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── LLM Providers (get free API keys below) ───────────
# Groq     → https://console.groq.com        (free)
GROQ_API_KEY=your_groq_api_key_here

# OpenCode → https://opencode.ai/auth         (free)
OPENCODE_API_KEY=your_opencode_api_key_here

# Mistral  → https://console.mistral.ai       (free tier)
MISTRAL_API_KEY=your_mistral_api_key_here

# Cohere   → https://dashboard.cohere.com     (free trial)
COHERE_API_KEY=your_cohere_api_key_here

# Nvidia NIM 
NVIDIA_API_KEY=your_nvidia_api_key_here

# ── Email Alerts ──────────────────────────────────────
# Use Gmail App Password (not regular password)
# Enable at: myaccount.google.com/apppasswords
EMAIL_SENDER=your@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECEIVER=alerts@yourcompany.com

# ── Slack Alerts ──────────────────────────────────────
# Create at: api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── PagerDuty (optional) ──────────────────────────────
PAGERDUTY_ROUTING_KEY=your_pagerduty_routing_key

# ── Microsoft Teams (optional) ────────────────────────
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx

# ── Kubernetes ────────────────────────────────────────
K8S_NAMESPACE=default
K8S_TIMEOUT=30

# ── AWS (for production deployment) ───────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET=devops-swarm-outputs

# ── Monitoring ────────────────────────────────────────
METRICS_ENABLED=True